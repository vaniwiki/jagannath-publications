---
interface Props {
  active?: string; // 'english' | 'hindi' | 'bengali' | 'russian' | undefined
}

const { active } = Astro.props;

const languages = [
  { slug: 'english', label: 'ENGLISH' },
  { slug: 'russian', label: 'РУССКИЙ' },
  { slug: 'hindi', label: 'हिंदी' },
  { slug: 'bengali', label: 'বাংলা' },
];
---

<div class="lang-pills">
  {languages.map(l => (
    <a
      href={`/books/language/${l.slug}/`}
      class:list={['lang-pill', active === l.slug ? 'is-active' : '']}
    >
      {l.label}
    </a>
  ))}
</div>

<style>
  .lang-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .lang-pills { gap: 1rem; }
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    padding: 0.75rem 1.75rem;
    border-radius: 9999px;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    white-space: nowrap;
    color: var(--text-primary);
    background: #fdfbf7;
    border: 1.5px solid rgba(0, 0, 0, 0.18);
    box-shadow: 0 2px 8px rgba(74, 28, 21, 0.06);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  @media (min-width: 640px) {
    .lang-pill {
      min-width: 180px;
      padding: 0.875rem 2.25rem;
      font-size: 1rem;
    }
  }
  .lang-pill:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(74, 28, 21, 0.12);
  }

  /* Active — orange (#e67e22) with warm glow */
  .lang-pill.is-active {
    color: #fff;
    background: #e67e22;
    border-color: #e67e22;
    box-shadow:
      0 0 0 4px rgba(230, 126, 34, 0.18),
      0 8px 22px rgba(230, 126, 34, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .lang-pill.is-active:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
</style>
