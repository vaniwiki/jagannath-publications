---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 32 } = Astro.props;
---

<!-- Peacock feather logo mark -->
<svg
  viewBox="0 0 64 64"
  width={size}
  height={size}
  class={className}
  aria-label="Jagannath Publications logo"
>
  <!-- Outer feather shape -->
  <path
    d="M32 2C32 2 12 24 12 38C12 49.05 20.95 58 32 58C43.05 58 52 49.05 52 38C52 24 32 2 32 2Z"
    class="fill-peacock-400 dark:fill-peacock-300"
    opacity="0.15"
  />
  <!-- Middle feather -->
  <path
    d="M32 12C32 12 18 28 18 38C18 45.73 24.27 52 32 52C39.73 52 46 45.73 46 38C46 28 32 12 32 12Z"
    class="fill-peacock-400 dark:fill-peacock-300"
    opacity="0.25"
  />
  <!-- Inner eye shape -->
  <ellipse
    cx="32" cy="39"
    rx="9" ry="11"
    class="fill-peacock-500 dark:fill-peacock-400"
    opacity="0.4"
  />
  <!-- Eye core -->
  <ellipse
    cx="32" cy="39"
    rx="5" ry="6.5"
    class="fill-saffron-400 dark:fill-saffron-300"
    opacity="0.6"
  />
  <!-- Eye center dot -->
  <ellipse
    cx="32" cy="39"
    rx="2" ry="2.8"
    class="fill-peacock-600 dark:fill-peacock-400"
    opacity="0.7"
  />
  <!-- Feather quill line -->
  <line
    x1="32" y1="2" x2="32" y2="58"
    class="stroke-saffron-400 dark:stroke-saffron-300"
    stroke-width="0.8"
    opacity="0.3"
  />
</svg>
