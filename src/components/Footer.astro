---
---

<footer class="footer-root relative overflow-hidden">
  <div class="footer-temple-wrap" aria-hidden="true">
    <img src="/images/temple-silhouette-footer.png" alt="" class="footer-temple" />
    <span class="sun-glow"></span>
  </div>

  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10 sm:py-12 relative z-10">
    <div class="grid sm:grid-cols-[1fr_1fr] gap-8 sm:gap-12 mb-8">
      <div>
        <a href="/" class="flex items-center gap-3 mb-3">
          <img src="/images/logo-books.png" alt="" class="w-10 h-10 object-contain" />
          <div class="leading-tight">
            <span class="font-display text-lg font-bold text-[var(--text-primary)] block">Jagannath</span>
            <span class="font-display text-sm text-[var(--text-muted)] block">Publications</span>
          </div>
        </a>
      </div>

      <div class="sm:text-right">
        <p class="font-display text-sm text-[var(--text-muted)] mb-3">
          Questions? Chat with us on WhatsApp
        </p>
        <div class="flex sm:justify-end gap-3">
          <a href="https://wa.me/917903291954" target="_blank" rel="noopener"
             class="social-btn"
             aria-label="WhatsApp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 22h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          </a>
          <a href="mailto:info@jagannathpublications.com" class="social-btn" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-[var(--border)] pt-5">
      <div class="flex flex-wrap gap-x-6 gap-y-2 font-display text-sm text-[var(--text-muted)] mb-2">
        <a href="/about/" class="hover:text-[var(--text-primary)] transition">About Us</a>
        <a href="/biography/" class="hover:text-[var(--text-primary)] transition">Biography</a>
        <a href="/contact/" class="hover:text-[var(--text-primary)] transition">Contact Us</a>
        <a href="/privacy-policy/" class="hover:text-[var(--text-primary)] transition">Privacy Policy</a>
        <a href="/shipping-policy/" class="hover:text-[var(--text-primary)] transition">Shipping Policy</a>
        <a href="/disclaimer/" class="hover:text-[var(--text-primary)] transition">Disclaimer</a>
      </div>
      <p class="font-display text-xs text-[var(--text-subtle)]">
        © {new Date().getFullYear()} Jagannath Publications. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    background: var(--bg-secondary);
    min-height: 280px;
  }

  .footer-temple-wrap {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 42%;
    max-width: 360px;
    height: 100%;
    max-height: 220px;
    pointer-events: none;
    z-index: 0;
  }

  .footer-temple {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 100%;
    height: auto;
    max-height: 100%;
    object-fit: contain;
    object-position: bottom right;
    opacity: 0.55;
  }

  .sun-glow {
    position: absolute;
    top: 22%;
    right: 68%;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: radial-gradient(circle, #f5b638 0%, #f9a51a 55%, transparent 100%);
    filter: blur(1px);
    opacity: 0.9;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    border: 1px solid var(--border-strong);
    color: var(--text-primary);
    background: var(--bg-secondary);
    transition: all 0.2s ease;
  }
  .social-btn:hover {
    border-color: var(--brand);
    color: var(--brand);
  }

  @media (max-width: 640px) {
    .footer-temple-wrap {
      width: 55%;
      max-height: 150px;
    }
    .sun-glow {
      width: 28px;
      height: 28px;
      top: 12%;
      right: 72%;
    }
  }
</style>
