---
---

<footer class="footer-outer">
  <!-- Temple lives here, OUTSIDE the card -->
  <div class="footer-scene-bg" aria-hidden="true">
    <img src="/images/temple-silhouette-footer.png" alt="" class="temple" />
  </div>

  <div class="footer-card">
    <!-- Sun + birds stay INSIDE the card -->
    <div class="footer-scene" aria-hidden="true">
      <span class="sun"></span>
      <svg class="birds" viewBox="0 0 90 32" fill="none">
        <path d="M3 18 C6 14, 9 14, 12 18 C15 14, 18 14, 21 18"
              stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" opacity="0.75"/>
        <path d="M30 10 C33 7, 36 7, 39 10 C42 7, 45 7, 48 10"
              stroke="currentColor" stroke-width="1.1" stroke-linecap="round" fill="none" opacity="0.6"/>
        <path d="M56 22 C58 20, 60 20, 62 22 C64 20, 66 20, 68 22"
              stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.55"/>
      </svg>
    </div>

    <!-- Top row: brand + contact -->
    <div class="footer-top">
      <a href="/" class="footer-brand">
        <img src="/images/logo-books.png" alt="" class="footer-logo" />
        <div class="leading-tight">
          <span class="font-display text-lg sm:text-xl font-bold text-[var(--text-primary)] block">
            Jagannath
          </span>
          <span class="font-display text-sm sm:text-base text-[var(--text-muted)] block">
            Publications
          </span>
        </div>
      </a>

      <div class="footer-contact">
        <p class="footer-contact-text">
          Questions?<br />Chat with us on WhatsApp
        </p>
        <div class="footer-icons">
          <a
            href="https://wa.me/917903291954"
            target="_blank"
            rel="noopener"
            class="whatsapp-bubble"
            aria-label="WhatsApp"
          >
            <img src="/images/whasapp-icon.png" alt="" class="icon-img" />
          </a>
          <div class="email-stack">
            <a href="mailto:info@jagannathpublications.com" class="email-icon" aria-label="Email">
              <img src="/images/email-icon.png" alt="" class="icon-img" />
            </a>
            <span class="email-caption">e-mail</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom-left stacked links + copyright -->
    <div class="footer-bottom">
      <nav class="footer-links">
        <a href="/about/">About Us</a>
        <a href="/contact/">Contact Us</a>
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/shipping-policy/">Shipping Policy</a>
        <a href="/disclaimer/">Disclaimer</a>
      </nav>
      <p class="footer-copy">
        © {new Date().getFullYear()} Jagannath Publications. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Outer stage ── */
  .footer-outer {
      
    position: relative;
    padding: 1.25rem 1rem 0;
    background: transparent;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .footer-outer { padding: 2rem 1.5rem 0; }
  }
  @media (min-width: 1024px) {
    .footer-outer { padding: 2.5rem 2rem 0; }
  }

  /* ── Temple — fixed height so it doesn't grow too tall ── */
  .footer-scene-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .temple {
    position: absolute;
    bottom: 0;
    right: 2rem;
    width: auto;
    height: 85%;          /* controls how much temple shows — tweak this */
    max-height: 340px;    /* hard cap so it never gets too tall */
    object-fit: contain;
    object-position: bottom right;
  }
  @media (min-width: 640px) {
    .temple { right: 2.5rem; max-height: 360px; }
  }
  @media (min-width: 1024px) {
    .temple { right: 3.5rem; max-height: 400px; }
  }
  @media (max-width: 640px) {
    .temple { right: 0.5rem; max-height: 280px; height: 80%; }
  }

  /* ── Card — transparent, normal margin: 0 auto centering ── */
  .footer-card {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    background: rgba(250, 246, 238, 0.25);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 28px;
    box-shadow:
      0 8px 32px rgba(74, 28, 21, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    padding: 1.75rem 1.5rem 1.5rem;
    min-height: 260px;
    /* Temple peeks up from below the card bottom edge */
    padding-bottom: 2rem;
  }
  @media (min-width: 640px) {
    .footer-card {
      padding: 2.5rem 2.5rem 3rem;
      border-radius: 36px;
      min-height: 280px;
    }
  }
  @media (min-width: 1024px) {
    .footer-card {
      padding: 3rem 3.5rem 4rem;
      min-height: 300px;
    }
  }
  @media (max-width: 640px) {
    .footer-card { padding-bottom: 2rem; }
  }

  /* ── Sun + birds (inside card) ── */
  .footer-scene {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .sun {
    position: absolute;
    bottom: 28%;
    right: 36%;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      #fcd34d 0%,
      #f9a51a 55%,
      rgba(249, 165, 26, 0.15) 80%,
      transparent 100%
    );
    box-shadow: 0 0 30px rgba(249, 165, 26, 0.45);
  }
  .birds {
    position: absolute;
    bottom: 22%;
    right: 44%;
    width: 95px;
    height: 32px;
    color: #3a2a1e;
  }
  @media (max-width: 1024px) {
    .sun  { width: 42px; height: 42px; bottom: 30%; right: 34%; }
    .birds { width: 72px; bottom: 22%; right: 42%; }
  }
  @media (max-width: 640px) {
    .sun  { width: 30px; height: 30px; bottom: 28%; right: 38%; }
    .birds { width: 55px; bottom: 18%; right: 42%; height: 22px; }
  }

  /* ── Top row ── */
  .footer-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-top { margin-bottom: 3rem; }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .footer-logo {
    width: 44px; height: 44px;
    object-fit: contain;
  }
  @media (min-width: 640px) {
    .footer-logo { width: 52px; height: 52px; }
  }

  .footer-contact {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }
  .footer-contact-text {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    text-align: right;
  }
  @media (min-width: 640px) {
    .footer-contact-text { font-size: 1.05rem; }
  }
  @media (max-width: 480px) {
    .footer-contact-text { font-size: 0.8rem; }
  }

  .footer-icons {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .whatsapp-bubble {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    background: transparent;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .whatsapp-bubble:hover {
    transform: translateY(-1px);
  }

  .email-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .email-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    transition: transform 0.2s ease;
  }
  .email-icon:hover {
    transform: translateY(-1px);
  }

  .icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .email-caption {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.625rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* ── Bottom links + copyright ── */
  .footer-bottom {
    position: relative;
    z-index: 1;
    max-width: 50%;
  }
  @media (max-width: 640px) {
    .footer-bottom { max-width: 48%; }
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .footer-links a {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
    width: fit-content;
  }
  .footer-links a:hover { color: var(--brand); }
  @media (min-width: 640px) {
    .footer-links a { font-size: 1.05rem; }
  }
  @media (max-width: 640px) {
    .footer-links { gap: 0.375rem; margin-bottom: 0.875rem; }
    .footer-links a { font-size: 0.875rem; }
  }

  .footer-copy {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .footer-copy { font-size: 0.7rem; }
  }
</style>
