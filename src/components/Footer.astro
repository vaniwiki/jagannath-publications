---
import PeacockLogo from './PeacockLogo.astro';
---

<footer style="background:var(--bg-secondary)">

  <!-- Info area (temple lives here, relative to this wrapper) -->
  <div class="relative">

  <!-- Info (constrained) -->
  <div class="max-w-6xl mx-auto px-6 sm:px-10 relative z-10 py-8">
    <a href="/" class="flex items-center gap-2.5 mb-5">
      <PeacockLogo size={28} />
      <div class="leading-tight">
        <span class="font-display text-lg font-bold text-[var(--text-secondary)] block" style="letter-spacing:0.04em">Jagannath</span>
        <span class="font-sans text-[9.5px] font-bold uppercase text-[var(--text-muted)] block" style="letter-spacing:0.32em">Publications</span>
      </div>
    </a>

    <p class="font-body text-sm text-[var(--text-muted)] max-w-xs leading-relaxed mb-5">
      The sacred literature of Srila Gour Govinda Swami Maharaja. Over 80 titles in English, Hindi, Bengali, and Russian.
    </p>

    <div class="flex items-center gap-3 mb-6">
      <a href="https://wa.me/917903291954" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--border)] text-[var(--text-muted)] hover:text-[var(--text-secondary)] hover:border-[var(--border-strong)] transition font-sans text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.15 15.15 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"/></svg>
        WhatsApp
      </a>
      <a href="mailto:info@jagannathpublications.com" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-[var(--border)] text-[var(--text-muted)] hover:text-[var(--text-secondary)] hover:border-[var(--border-strong)] transition font-sans text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
        Email
      </a>
    </div>

    <div class="flex flex-wrap gap-x-6 gap-y-1 font-sans text-sm text-[var(--text-muted)] mb-4">
      <a href="/#about" class="hover:text-[var(--text-secondary)] transition">About</a>
      <a href="/books/" class="hover:text-[var(--text-secondary)] transition">Books</a>
      <a href="#" class="hover:text-[var(--text-secondary)] transition">Privacy</a>
      <a href="#" class="hover:text-[var(--text-secondary)] transition">Shipping</a>
    </div>

    <p class="font-sans text-xs text-[var(--text-subtle)]">
      &copy; {new Date().getFullYear()} Jagannath Publications. All Rights Reserved.
    </p>
  </div>

  <!-- Sun/Moon — position calculated by time of day, clickable for timelapse -->
  <div id="celestial" class="absolute z-10" style="right:17%;top:10%">
    <!-- Sun -->
    <div id="cel-sun" class="w-10 h-10 rounded-full" style="background:#d4a934;box-shadow:0 0 30px 12px rgba(212,169,52,0.35),0 0 60px 20px rgba(212,169,52,0.1);display:none"></div>
    <!-- Moon (phase rendered dynamically) -->
    <div id="cel-moon" class="relative" style="width:36px;height:36px;display:none;filter:drop-shadow(0 0 12px rgba(232,220,200,0.35)) drop-shadow(0 0 30px rgba(232,220,200,0.15))">
      <div style="width:36px;height:36px;overflow:hidden;border-radius:50%;position:relative">
        <div id="moon-lit" class="absolute inset-0 rounded-full" style="background:#e8dcc8"></div>
        <div id="moon-shadow" class="absolute rounded-full" style="top:0;width:36px;height:36px"></div>
      </div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var sun = document.getElementById('cel-sun');
      var moon = document.getElementById('cel-moon');
      var shadow = document.getElementById('moon-shadow');
      if (!sun || !moon || !shadow) return;

      function applyMoonPhase() {
        var now = new Date();
        var y = now.getFullYear(), m = now.getMonth() + 1, d = now.getDate();
        if (m <= 2) { y--; m += 12; }
        var A = Math.floor(y / 100), B = Math.floor(A / 4), C = 2 - A + B;
        var E = Math.floor(365.25 * (y + 4716)), F = Math.floor(30.6001 * (m + 1));
        var JD = C + d + E + F - 1524.5;
        var age = ((JD - 2451550.1) % 29.53058770576 + 29.53058770576) % 29.53058770576;
        var phase = age / 29.53058770576;
        var illum = 0.5 - 0.5 * Math.cos(phase * 2 * Math.PI);

        shadow.style.background = document.documentElement.classList.contains('dark') ? '#1c1210' : '#faf6ee';

        if (illum > 0.97) { shadow.style.display = 'none'; return; }
        shadow.style.display = 'block';
        shadow.style.width = '36px'; shadow.style.height = '36px';
        var offset = Math.round(illum * 36);
        if (illum < 0.03) { shadow.style.left = '0px'; shadow.style.right = 'auto'; }
        else if (phase < 0.5) { shadow.style.left = (-offset) + 'px'; shadow.style.right = 'auto'; }
        else { shadow.style.left = offset + 'px'; shadow.style.right = 'auto'; }
      }

      function update() {
        var isDark = document.documentElement.classList.contains('dark');
        sun.style.display = isDark ? 'none' : 'block';
        moon.style.display = isDark ? 'block' : 'none';
        if (isDark) applyMoonPhase();
      }

      update();
      window._celestialUpdate = update;
    })();
  </script>

  <!-- Temple silhouette — flush to bottom of info area, right edge of viewport -->
  <img
    src="/images/temple-silhouette-footer.png"
    alt=""
    aria-hidden="true"
    class="footer-temple"
  />

  </div><!-- end info area wrapper -->

  <!-- Full-width quote bar (the actual bottom of the page) -->
  <div class="footer-bar">
    <div class="max-w-3xl mx-auto px-6 py-10 sm:py-14 text-center">
      <blockquote class="font-display text-xl sm:text-2xl md:text-3xl text-parchment-200/80 font-bold italic leading-relaxed">
        &ldquo;The most important thing is hearing. Unless you hear, nothing will happen.&rdquo;
      </blockquote>
      <footer class="mt-5 font-sans text-xs text-saffron-400/50 tracking-wider uppercase">
        Srila Gour Govinda Swami Maharaja
      </footer>
    </div>
  </div>

</footer>

<style>
  .footer-temple {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 35%;
    max-width: 480px;
    min-width: 250px;
    height: auto;
    display: block;
    pointer-events: none;
    z-index: 15;
  }
  :global(.dark) .footer-temple {
    opacity: 1;
    filter: brightness(0.35);
  }

  .footer-bar {
    width: 100%;
    background: #2d241e;
    position: relative;
    z-index: 0;
  }
  :global(.dark) .footer-bar {
    background: #100d0b;
  }

  @media (max-width: 640px) {
    .footer-temple {
      width: 55%;
      max-width: none;
      height: auto;
      bottom: 0;
      right: 0;
      opacity: 0.2;
    }
  }
</style>
