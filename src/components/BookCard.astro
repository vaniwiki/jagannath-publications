---
import SmartImage from './SmartImage.astro';

interface Props {
  slug: string;
  title: string;
  language: string;
  coverFront: string;
  price?: number;
  currency?: string;
}

const { slug, title, language, coverFront, price, currency = 'INR' } = Astro.props;

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';

const safeTitle = title.replace(/'/g, "\\'");
---

<div class="book-card flex flex-col h-full">
  <!-- Cover -->
  <a href={`/books/${slug}/`} class="book-cover-link">
    <SmartImage
      src={coverFront}
      alt={title}
      class="book-cover-img"
      loading="lazy"
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
    />
  </a>

  <!-- Info -->
  <a href={`/books/${slug}/`} class="block mt-3 flex-1">
    <h3 class="font-display text-sm sm:text-base font-bold text-[var(--text-primary)] leading-snug hover:text-brand-500 transition-colors line-clamp-2">
      {title}
    </h3>
    <div class="flex items-center gap-2 mt-1 font-display text-xs text-[var(--text-muted)]">
      <span>{language.toUpperCase()}</span>
      {priceDisplay && <span>| {priceDisplay}</span>}
    </div>
  </a>

  <!-- Add to Bag button (mirrors Canva "ADD TO BAG" / "Added!" states) -->
  <button
    data-cart-btn={slug}
    data-title={title}
    data-language={language}
    class="add-to-bag-btn mt-3 w-full py-2 rounded-full font-display text-xs font-semibold tracking-wide transition-all border-2 border-[var(--border-strong)] text-[var(--text-primary)] bg-transparent hover:border-brand-500 hover:text-brand-500"
  >
    ADD TO BAG
  </button>
</div>

<style>
  .book-cover-link {
    display: block;
    position: relative;
    aspect-ratio: 2/3;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(74, 28, 21, 0.12);
    background: var(--bg-secondary);
  }
  .book-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .book-cover-link:hover .book-cover-img {
    transform: scale(1.04);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
