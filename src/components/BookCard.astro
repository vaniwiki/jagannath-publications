---
import SmartImage from './SmartImage.astro';

interface Props {
  slug: string;
  title: string;
  language: string;
  coverFront: string;
  price?: number;
  currency?: string;
}

const { slug, title, language, coverFront, price, currency = 'INR' } = Astro.props;

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';
---

<div class="book-card">
  <!-- Everything lives inside the frame: image + title + meta -->
  <a href={`/books/${slug}/`} class="book-card__frame" aria-label={title}>
    <div class="book-card__img-wrap">
      <SmartImage
        src={coverFront}
        alt={title}
        class="book-card__img"
        loading="lazy"
        sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      />
    </div>

    <div class="book-card__info">
      <h3 class="book-card__title">{title}</h3>
      <div class="book-card__meta">
        <span>{language.toUpperCase()}</span>
        {priceDisplay && <span>| {priceDisplay}</span>}
      </div>
    </div>
  </a>

  <!-- Add to Bag button sits outside the frame -->
  <button
    data-cart-btn={slug}
    data-title={title}
    data-language={language}
    class="add-to-bag-btn book-card__cta"
  >
    <img src="/images/bag.png" alt="" class="add-to-bag-btn__icon" />
    <span class="add-to-bag-btn__label">ADD TO BAG</span>
  </button>
</div>

<style>
  .book-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-width: 240px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Frame — grows to fill equal height across the row ── */
  .book-card__frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;                                 /* fills available vertical space so every frame equal height */
    padding: 1.5rem 1rem 1.25rem;
    border-radius: 1rem;
    background: rgba(250, 246, 238, 0.25);
    border: 1px solid rgba(0, 0, 0, 0.12);
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  .book-card__frame:hover {
    transform: translateY(-3px);
  }
  @media (min-width: 640px) {
    .book-card__frame { padding: 1.75rem 1.1rem 1.35rem; border-radius: 1.15rem; }
  }
  @media (min-width: 1024px) {
    .book-card__frame { padding: 2rem 1.25rem 1.5rem; }
  }

  /* Image wrap — centers book in a fixed height */
  .book-card__img-wrap {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 110px;
    margin-bottom: 1rem;
  }
  @media (min-width: 640px) {
    .book-card__img-wrap { height: 190px; margin-bottom: 1.1rem; }
  }
  @media (min-width: 1024px) {
    .book-card__img-wrap { height: 310px; margin-bottom: 1.25rem; }
  }

  /* Book image — smaller, uplifted with shadow */
  .book-card__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: 0.35rem;
    box-shadow:
      0 14px 28px rgba(74, 28, 21, 0.32),
      0 5px 10px rgba(74, 28, 21, 0.20);
    transition: transform 0.4s ease;
  }
  .book-card__frame:hover .book-card__img {
    transform: scale(1.04);
  }

  /* Title + meta inside the frame, centered. Info block fills remaining space
     so cards with 1-line titles and 2-line titles still have equal total height. */
  .book-card__info {
    width: 100%;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .book-card__title {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    /* Always reserve space for 2 lines — keeps meta row aligned across all cards */
    min-height: calc(0.9rem * 1.3 * 2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 0.35rem 0;
  }
  @media (min-width: 640px) {
    .book-card__title {
      font-size: 1rem;
      min-height: calc(1rem * 1.3 * 2);
    }
  }
  .book-card__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  /* Bag icon — 50% bigger than the default 16 */
  .book-card__cta .add-to-bag-btn__icon {
    width: 24px;
    height: 24px;
  }

  /* ── Add to Bag pill — default: WHITE, shorter & taller ── */
  .book-card__cta {
    margin: 0.9rem auto 0;
    width: 85%;
    max-width: 200px;
    padding: 0.85rem 0.75rem;
    border-radius: 9999px;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #2a1810;
    background: #fdfbf7;
    border: 2px solid #2a1810;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    box-shadow: 0 2px 6px rgba(74, 28, 21, 0.06);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .book-card__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(74, 28, 21, 0.10);
  }

  /* Active "Added" state — yellow pill */
  .book-card__cta.is-added {
    color: #2a1810;
    background: #f5b61a;
    border-color: #2a1810;
    box-shadow: 0 4px 12px rgba(245, 182, 26, 0.32);
  }
  .book-card__cta.is-added:hover {
    box-shadow: 0 6px 16px rgba(245, 182, 26, 0.4);
  }
</style>
