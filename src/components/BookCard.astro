---
import SmartImage from './SmartImage.astro';

interface Props {
  slug: string;
  title: string;
  language: string;
  coverFront: string;
  price?: number;
  currency?: string;
}

const { slug, title, language, coverFront, price, currency = 'INR' } = Astro.props;

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';
---

<div class="book-card">
  <!-- Cover area — uniform aspect ratio, transparent container like the author card -->
  <a href={`/books/${slug}/`} class="book-card__cover" aria-label={title}>
    <SmartImage
      src={coverFront}
      alt={title}
      class="book-card__img"
      loading="lazy"
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
    />
  </a>

  <!-- Info -->
  <a href={`/books/${slug}/`} class="book-card__info">
    <h3 class="book-card__title">{title}</h3>
    <div class="book-card__meta">
      <span>{language.toUpperCase()}</span>
      {priceDisplay && <span>| {priceDisplay}</span>}
    </div>
  </a>

  <!-- Add to Bag button -->
  <button
    data-cart-btn={slug}
    data-title={title}
    data-language={language}
    class="add-to-bag-btn book-card__cta"
  >
    <img src="/images/bag.png" alt="" class="add-to-bag-btn__icon" />
    <span class="add-to-bag-btn__label">ADD TO BAG</span>
  </button>
</div>

<style>
  .book-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-width: 240px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Cover container — transparent like the author card, with soft shadow ── */
  .book-card__cover {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    aspect-ratio: 3 / 4;              /* uniform frame for every book */
    border-radius: 1rem;
    padding: 1rem;
    background: rgba(250, 246, 238, 0.25);
    border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow:
      0 14px 32px rgba(74, 28, 21, 0.18),
      0 4px 10px rgba(74, 28, 21, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .book-card__cover:hover {
    box-shadow:
      0 22px 48px rgba(74, 28, 21, 0.26),
      0 6px 14px rgba(74, 28, 21, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transform: translateY(-4px);
  }

  /* Book image — uniform size across every card */
  .book-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 0.5rem;
    box-shadow: 0 8px 20px rgba(74, 28, 21, 0.22);
    transition: transform 0.5s ease;
  }
  .book-card__cover:hover .book-card__img {
    transform: scale(1.04);
  }

  @media (min-width: 640px) {
    .book-card__cover { padding: 1.1rem; border-radius: 1.15rem; }
  }
  @media (min-width: 1024px) {
    .book-card__cover { padding: 1.2rem; }
  }

  /* ── Info block ── */
  .book-card__info {
    display: block;
    margin-top: 0.75rem;
    flex: 1;
    text-decoration: none;
  }
  .book-card__title {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .book-card__title { font-size: 1rem; }
  }

  .book-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Icon sizing for compact listing-card button */
  .book-card__cta .add-to-bag-btn__icon {
    width: 16px;
    height: 16px;
  }

  /* ── Add to Bag (listing card) — default: WHITE pill with dark border ── */
  .book-card__cta {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 0.9rem;
    border-radius: 9999px;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #2a1810;
    background: #fdfbf7;
    border: 2px solid #2a1810;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    box-shadow: 0 2px 6px rgba(74, 28, 21, 0.06);
    /* no color/bg change on hover — just a subtle lift */
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .book-card__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(74, 28, 21, 0.10);
  }

  /* Active "Added!" state — yellow pill (overrides the default white via .is-added) */
  .book-card__cta.is-added {
    color: #2a1810;
    background: #f5b61a;
    border-color: #2a1810;
    box-shadow: 0 4px 12px rgba(245, 182, 26, 0.32);
  }
  .book-card__cta.is-added:hover {
    box-shadow: 0 6px 16px rgba(245, 182, 26, 0.4);
  }
</style>
