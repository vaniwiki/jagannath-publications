---
import { getCollection } from 'astro:content';

// Build a lookup map so the cart can show cover + price + weight for each slug
const allBooks = await getCollection('books');
const cartLookup = allBooks.reduce((acc, b) => {
  acc[b.slug] = {
    title: b.data.title,
    language: b.data.language,
    price: b.data.price ?? 0,
    currency: b.data.currency ?? 'INR',
    coverFront: b.data.coverFront,
    weight: b.data.dimensions?.weight ?? 0,
  };
  return acc;
}, {});
---

<!-- Overlay -->
<div id="cart-overlay" class="cart-overlay fixed inset-0 bg-black/20 backdrop-blur-sm z-40" onclick="toggleCart()"></div>

<!-- Drawer -->
<aside id="cart-drawer" class="cart-drawer fixed top-0 right-0 h-full w-full sm:w-[440px] bg-[var(--bg-primary)] z-50 shadow-2xl flex flex-col">
  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-[var(--border)]">
    <h2 class="font-display text-2xl font-bold text-[var(--text-primary)]">Your Selection</h2>
    <button onclick="toggleCart()" class="p-1.5 text-[var(--text-muted)] hover:text-[var(--text-primary)] transition" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Items -->
  <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4"></div>

  <!-- Footer (totals + actions) -->
  <div id="cart-footer" class="px-6 py-5 border-t border-[var(--border)] hidden">
    <div class="space-y-2 mb-5 font-display text-sm">
      <div class="flex justify-between text-[var(--text-muted)]">
        <span>Total Books</span>
        <span id="cart-total-books" class="text-[var(--text-primary)] font-medium">0</span>
      </div>
      <div class="flex justify-between text-[var(--text-muted)]">
        <span>Est. Weight</span>
        <span id="cart-total-weight" class="text-[var(--text-primary)] font-medium">0g</span>
      </div>
      <div class="flex justify-between text-[var(--text-muted)]">
        <span>Total Amount</span>
        <span id="cart-total-amount" class="text-[var(--text-primary)] font-semibold">₹0</span>
      </div>
    </div>

    <button
      onclick="cartCheckoutWhatsApp()"
      class="w-full flex items-center justify-center gap-2.5 py-3 bg-[#25d366] hover:bg-[#1fb856] text-white rounded-full font-display font-semibold text-sm transition shadow-md mb-2.5"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 22h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
      Order via WhatsApp
    </button>

    <button
      onclick="cartCheckoutEmail()"
      class="w-full flex items-center justify-center gap-2.5 py-3 border-2 border-[var(--border-strong)] text-[var(--text-primary)] rounded-full font-display font-semibold text-sm hover:border-[var(--text-primary)] transition mb-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
      Order via Email
    </button>

    <button onclick="cartClear()" class="w-full py-2 font-display text-xs text-[var(--text-muted)] hover:text-[var(--text-primary)] transition">
      Clear Selection
    </button>
  </div>
</aside>

<script is:inline define:vars={{ cartLookup }}>
  const WHATSAPP = '917903291954';
  const EMAIL = 'info@jagannathpublications.com';
  const CART_VERSION = 3;

  let cartItems = [];
  try {
    const stored = JSON.parse(localStorage.getItem('jp-cart') || '[]');
    const ver = localStorage.getItem('jp-cart-v');
    if (ver === String(CART_VERSION) && Array.isArray(stored) && stored.every(i => i.slug)) {
      cartItems = stored.map(i => ({ ...i, qty: i.qty || 1 }));
    } else {
      localStorage.removeItem('jp-cart');
      localStorage.setItem('jp-cart-v', String(CART_VERSION));
    }
  } catch { localStorage.removeItem('jp-cart'); }

  function toggleCart() {
    document.getElementById('cart-drawer').classList.toggle('open');
    document.getElementById('cart-overlay').classList.toggle('open');
  }
  window.toggleCart = toggleCart;

  function cartAdd(slug, title, language) {
    const existing = cartItems.find(i => i.slug === slug);
    if (existing) {
      existing.qty++;
    } else {
      cartItems.push({ slug, title, language, qty: 1 });
    }
    cartSave();
  }
  window.cartAdd = cartAdd;

  function cartSetQty(slug, qty) {
    const item = cartItems.find(i => i.slug === slug);
    if (!item) return;
    if (qty <= 0) cartRemove(slug);
    else { item.qty = qty; cartSave(); }
  }
  window.cartSetQty = cartSetQty;

  function cartRemove(slug) {
    cartItems = cartItems.filter(i => i.slug !== slug);
    cartSave();
  }
  window.cartRemove = cartRemove;

  function cartClear() { cartItems = []; cartSave(); }
  window.cartClear = cartClear;

  function cartSave() {
    localStorage.setItem('jp-cart', JSON.stringify(cartItems));
    localStorage.setItem('jp-cart-v', String(CART_VERSION));
    cartRender();
  }

  function cartTotalQty() {
    return cartItems.reduce((s, i) => s + i.qty, 0);
  }
  function cartTotalWeight() {
    return cartItems.reduce((s, i) => {
      const w = (cartLookup[i.slug] && cartLookup[i.slug].weight) || 0;
      return s + w * i.qty;
    }, 0);
  }
  function cartTotalAmount() {
    return cartItems.reduce((s, i) => {
      const p = (cartLookup[i.slug] && cartLookup[i.slug].price) || 0;
      return s + p * i.qty;
    }, 0);
  }
  function currencySymbol(slug) {
    const c = (cartLookup[slug] && cartLookup[slug].currency) || 'INR';
    return c === 'INR' ? '₹' : c + ' ';
  }

  function buildOrderMessage() {
    let msg = "Hare Krishna! I'd like to order:\n\n";
    cartItems.forEach((item, i) => {
      const info = cartLookup[item.slug] || {};
      const price = info.price || 0;
      const sym = info.currency === 'INR' ? '₹' : (info.currency || 'INR') + ' ';
      msg += `${i + 1}. ${item.title} (${item.language}) × ${item.qty} — ${sym}${price * item.qty}\n`;
    });
    msg += `\nTotal: ${cartTotalQty()} book(s)`;
    msg += `\nEst. Weight: ${cartTotalWeight()}g`;
    msg += `\nTotal Amount: ₹${cartTotalAmount()}`;
    msg += `\n\nPlease let me know availability and shipping. Thank you!`;
    return msg;
  }

  function cartCheckoutWhatsApp() {
    if (!cartItems.length) return;
    window.open(`https://wa.me/${WHATSAPP}?text=${encodeURIComponent(buildOrderMessage())}`, '_blank');
  }
  window.cartCheckoutWhatsApp = cartCheckoutWhatsApp;

  function cartCheckoutEmail() {
    if (!cartItems.length) return;
    const subject = 'Book Order — Jagannath Publications';
    window.location.href = `mailto:${EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(buildOrderMessage())}`;
  }
  window.cartCheckoutEmail = cartCheckoutEmail;

  function esc(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function truncate(s, n) {
    return s.length > n ? s.slice(0, n - 1).trim() + '…' : s;
  }

  function cartRender() {
    const badge = document.getElementById('cart-badge');
    const container = document.getElementById('cart-items');
    const footer = document.getElementById('cart-footer');
    const totalQty = cartTotalQty();

    if (badge) {
      badge.textContent = totalQty;
      badge.classList.toggle('hidden', totalQty === 0);
    }
    if (!container) return;

    if (cartItems.length === 0) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center h-full opacity-50 pt-12">
          <svg class="w-12 h-12 mb-3" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007"/>
          </svg>
          <p class="font-display text-sm">Your selection is empty</p>
        </div>`;
      footer.classList.add('hidden');
      updateCartButtons();
      return;
    }

    container.innerHTML = cartItems.map(item => {
      const info = cartLookup[item.slug] || {};
      const price = info.price || 0;
      const sym = info.currency === 'INR' ? '₹' : (info.currency || 'INR') + ' ';
      const cover = info.coverFront || '';
      return `
        <div class="flex items-center gap-3 py-3 border-b border-[var(--border)] last:border-0">
          <a href="/books/${item.slug}/" class="shrink-0 w-12 h-16 rounded overflow-hidden bg-[var(--bg-secondary)]">
            ${cover ? `<img src="${cover}" alt="" class="w-full h-full object-cover">` : ''}
          </a>
          <div class="flex-1 min-w-0">
            <p class="font-display text-sm font-semibold text-[var(--text-primary)] leading-snug">${esc(truncate(item.title, 24))}</p>
            <p class="font-display text-[11px] tracking-wider uppercase text-[var(--text-muted)] mt-0.5">${esc(item.language)} | ${sym}${price}</p>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <button onclick="cartSetQty('${item.slug}', ${item.qty - 1})" class="w-7 h-7 flex items-center justify-center rounded border border-[var(--border-strong)] text-[var(--text-primary)] hover:border-brand-500 hover:text-brand-500 transition text-sm">−</button>
            <span class="w-6 text-center font-display text-sm font-semibold text-[var(--text-primary)]">${item.qty}</span>
            <button onclick="cartSetQty('${item.slug}', ${item.qty + 1})" class="w-7 h-7 flex items-center justify-center rounded border border-[var(--border-strong)] text-[var(--text-primary)] hover:border-brand-500 hover:text-brand-500 transition text-sm">+</button>
          </div>
          <button onclick="cartRemove('${item.slug}')" class="p-1 text-[var(--text-subtle)] hover:text-red-500 transition shrink-0" aria-label="Remove">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
        </div>`;
    }).join('');

    footer.classList.remove('hidden');
    document.getElementById('cart-total-books').textContent = totalQty;
    document.getElementById('cart-total-weight').textContent = cartTotalWeight() + 'g';
    document.getElementById('cart-total-amount').textContent = '₹' + cartTotalAmount();
    updateCartButtons();
  }

  function updateCartButtons() {
    document.querySelectorAll('[data-cart-btn]').forEach(btn => {
      // Skip the detail-page main action (it has its own active class)
      const slug = btn.getAttribute('data-cart-btn');
      const item = cartItems.find(i => i.slug === slug);
      if (btn.classList.contains('add-to-bag-btn')) {
        if (item) {
          btn.textContent = `Added! (${item.qty})`;
          btn.dataset.active = '1';
          btn.classList.remove('border-[var(--border-strong)]', 'text-[var(--text-primary)]', 'bg-transparent');
          btn.classList.add('bg-brand-500', 'text-white', 'border-brand-500');
        } else if (btn.dataset.active === '1') {
          btn.textContent = btn.dataset.defaultText || 'ADD TO BAG';
          btn.dataset.active = '0';
          btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500');
          btn.classList.add('border-[var(--border-strong)]', 'text-[var(--text-primary)]', 'bg-transparent');
        }
      }
    });
  }
  window.updateCartButtons = updateCartButtons;

  // Wire up all add-to-bag buttons (delegation for dynamic content)
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.add-to-bag-btn');
    if (!btn) return;
    e.preventDefault();
    const slug = btn.getAttribute('data-cart-btn');
    const title = btn.getAttribute('data-title');
    const language = btn.getAttribute('data-language');
    if (!btn.dataset.defaultText) btn.dataset.defaultText = btn.textContent.trim();
    cartAdd(slug, title, language);
  });

  cartRender();
</script>
