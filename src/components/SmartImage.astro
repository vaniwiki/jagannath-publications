---
/**
 * SmartImage — serves WebP with JPEG fallback for images in public/.
 *
 * Why: Astro's <Image> component only optimizes files in src/assets/, not public/.
 * Since our book covers live in public/images/books/ (managed by Sveltia CMS),
 * we use a <picture> with pre-generated .webp files from scripts/optimize_images.mjs.
 */
interface Props {
  src: string;          // e.g. /images/books/foo/front.jpg
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: className = '',
  loading = 'lazy',
  fetchpriority,
  sizes,
} = Astro.props;

// Derive the webp path
const webpSrc = src.replace(/\.(jpe?g|png)$/i, '.webp');
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    sizes={sizes}
  />
</picture>
