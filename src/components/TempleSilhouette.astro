  <svg viewBox="0 0 800 300" class="w-full h-auto" preserveAspectRatio="xMidYMax meet">
    <!-- Sun (light mode) -->
    <circle cx="620" cy="80" r="35" class="fill-saffron-400 block dark:hidden" opacity="0.9" />
    <!-- Moon (dark mode) -->
    <g class="hidden dark:block">
      <circle cx="620" cy="80" r="30" fill="#e8ddc4" opacity="0.8" />
      <circle cx="632" cy="72" r="26" class="fill-maroon-900" />
    </g>

    <!-- Birds -->
    <g class="fill-none stroke-current opacity-30" stroke-width="1.2">
      <path d="M380 100 Q385 94 390 100 Q395 94 400 100" class="stroke-maroon-500 dark:stroke-parchment-300" />
      <path d="M400 88 Q404 83 408 88 Q412 83 416 88" class="stroke-maroon-500 dark:stroke-parchment-300" />
      <path d="M365 115 Q369 110 373 115 Q377 110 381 115" class="stroke-maroon-500 dark:stroke-parchment-300" />
