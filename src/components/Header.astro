---
import { getCollection } from 'astro:content';
import { excludeFeatured } from '../lib/books';

const allBooks = excludeFeatured(await getCollection('books'));
const searchIndex = allBooks
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
  .map((b) => ({
    title: b.data.title,
    subtitle: b.data.subtitle ?? '',
    slug: b.slug,
    lang: b.data.language,
  }));
---

<!--
  Floating oval header — padded from viewport edges so it reads as a pill
  rather than a full-width bar.
-->
<div class="header-shell fixed top-0 left-0 right-0 z-50 pt-3 sm:pt-4 px-3 sm:px-5">
  <nav id="navbar" class="glass-nav w-full mx-auto max-w-7xl">
    <div class="px-4 sm:px-6">
      <div class="flex items-center py-2.5 sm:py-3 gap-4 sm:gap-6">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group shrink-0">
          <img
            src="/images/logo-books.png"
            alt="Jagannath Publications"
            class="w-12 h-12 sm:w-14 sm:h-14 object-contain transition-transform group-hover:scale-105"
          />
          <div class="leading-tight">
            <span class="font-display text-xl sm:text-2xl font-bold text-black block">
              Jagannath
            </span>
            <span class="font-display text-sm sm:text-base text-black block">
              Publications
            </span>
          </div>
        </a>

        <!-- Spacer -->
        <div class="flex-1"></div>

        <!-- Search bar (desktop) -->
        <div class="hidden sm:flex w-full max-w-md">
          <div class="relative w-full">
            <input
              type="text"
              placeholder="Search books…"
              id="nav-search"
              autocomplete="off"
              class="nav-search-input w-full pl-5 pr-11 py-2.5 rounded-full border border-[var(--border-strong)] bg-white/60 text-base focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:border-transparent transition"
            />
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-black pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
        </div>

        <!-- Right side icons -->
        <div class="flex items-center gap-2 sm:gap-3 shrink-0 ml-3 sm:ml-4">
          <button
            onclick="toggleCart()"
            class="relative p-1.5 hover:opacity-80 transition"
            aria-label="Open cart"
          >
            <img src="/images/bag.png" alt="" class="w-11 h-11 sm:w-12 sm:h-12 object-contain" />
            <span
              id="cart-badge"
              class="absolute -top-0.5 -right-0.5 min-w-[22px] h-[22px] flex items-center justify-center text-[12px] font-bold bg-red-500 text-white rounded-full px-1 hidden shadow-sm"
            >0</span>
          </button>

          <button
            id="menu-toggle"
            class="p-2 text-black hover:text-[var(--accent)] transition"
            aria-label="Menu"
          >
            <svg class="w-8 h-8 sm:w-9 sm:h-9" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Floating glass dropdown menu -->
  <div id="mobile-menu" class="menu-hidden absolute right-4 sm:right-6 mt-2 w-64 origin-top-right">
    <div class="glass-menu rounded-2xl py-2">
      <div class="sm:hidden px-4 pt-2 pb-3 border-b border-black/10">
        <div class="relative">
          <input
            type="text"
            id="nav-search-mobile"
            autocomplete="off"
            placeholder="Search books…"
            class="nav-search-input w-full pl-4 pr-10 py-2 rounded-full border border-[var(--border-strong)] bg-white/60 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)] transition"
          />
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-black pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
        </div>
      </div>
      <nav class="flex flex-col text-center font-display text-base text-black">
        <a href="/books/" class="menu-item px-6 py-3 hover:bg-white/50 transition">Shop</a>
        <a href="/about/" class="menu-item px-6 py-3 hover:bg-white/50 transition">About Us</a>
        <a href="/biography/" class="menu-item px-6 py-3 hover:bg-white/50 transition">Biography</a>
        <a href="/contact/" class="menu-item px-6 py-3 hover:bg-white/50 transition">Contact Us</a>
        <a href="/disclaimer/" class="menu-item px-6 py-3 hover:bg-white/50 transition">Disclaimer</a>
      </nav>
    </div>
  </div>
</div>

<!--
  Portalled search dropdown — rendered as a direct child of <body> so it
  escapes the navbar's backdrop-filter stacking context. Positioned via JS
  to track whichever search input is currently focused.
-->
<div
  id="search-portal"
  class="search-results"
  role="listbox"
  aria-label="Search results"
  style="display:none; position:fixed; z-index:100;"
></div>

<style>
  .header-shell {
    pointer-events: none; /* let the page underneath stay scrollable around the pill */
    transition: transform 0.3s ease, opacity 0.3s ease;
    will-change: transform;
  }
  .header-shell > * {
    pointer-events: auto;
  }
  .header-shell.header-hidden {
    transform: translateY(-120%);
    opacity: 0;
    pointer-events: none;
  }
  .header-shell.header-hidden > * {
    pointer-events: none;
  }

  .glass-nav {
    background: rgba(250, 246, 238, 0.25);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 9999px;
    box-shadow:
      0 8px 32px rgba(74, 28, 21, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    position: relative;
  }
  .glass-nav::before {
    content: none;
  }
  .glass-nav > * {
    position: relative;
    z-index: 1;
  }

  .nav-search-input {
    font-family: 'Gatwick', Georgia, serif;
    color: #000;
  }
  .nav-search-input::placeholder {
    color: #000;
    opacity: 0.7;
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 350;
  }

  .glass-menu {
    background: linear-gradient(
      135deg,
      rgba(253, 251, 247, 0.92) 0%,
      rgba(250, 246, 238, 0.88) 100%
    );
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      0 12px 40px rgba(74, 28, 21, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .menu-item {
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  #mobile-menu {
    transition:
      opacity 0.22s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: top right;
  }
  #mobile-menu.menu-hidden {
    opacity: 0;
    transform: scale(0.85) translateY(-8px);
    pointer-events: none;
  }
  #mobile-menu.menu-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  /* ── Portalled search results ── */
  .search-results {
    background: #fdfbf7;
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow:
      0 20px 50px rgba(74, 28, 21, 0.18),
      0 4px 12px rgba(74, 28, 21, 0.08);
    overflow-y: auto;
    max-height: 60vh;
  }
  .search-results::-webkit-scrollbar {
    width: 6px;
  }
  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-results::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 3px;
  }
  .search-results :global(.search-result) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 18px;
    text-decoration: none;
    color: var(--text-primary);
    transition: background 0.12s ease;
    font-size: 15px;
    border-bottom: 1px solid var(--border);
  }
  .search-results :global(.search-result:last-child) {
    border-bottom: 0;
  }
  .search-results :global(.search-result:hover),
  .search-results :global(.search-result.active) {
    background: var(--bg-secondary);
  }
  .search-results :global(.search-result-title) {
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 700;
    color: var(--text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }
  .search-results :global(.search-result-lang) {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 13px;
    color: var(--accent-hover);
    font-weight: 400;
    flex-shrink: 0;
  }
  .search-results :global(.search-empty) {
    padding: 16px 18px;
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    font-family: 'Gatwick', Georgia, serif;
  }
  .search-results :global(.search-view-all) {
    display: block;
    padding: 11px 18px;
    text-align: center;
    text-decoration: none;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    position: sticky;
    bottom: 0;
    transition: background 0.15s ease;
  }
  .search-results :global(.search-view-all:hover) {
    background: var(--bg-primary);
    color: var(--accent-hover);
  }
</style>

<script is:inline define:vars={{ searchIndex }}>
  // Navbar shadow on scroll
  // Navbar: only visible at the top of the page; hidden the moment you scroll down
  // and stays hidden on scroll-up until you're back at the very top.
  (function () {
    var nav = document.getElementById('navbar');
    var shell = document.querySelector('.header-shell');
    if (!nav || !shell) return;

    var TOP_THRESHOLD = 20; // how close to the top before the header shows
    var ticking = false;

    function onScroll() {
      var currentY = window.scrollY;

      // Shadow update
      nav.style.boxShadow = currentY > 20
        ? '0 12px 36px rgba(74, 28, 21, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.5)'
        : '0 8px 32px rgba(74, 28, 21, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)';

      // Visibility: only shown at the very top
      if (currentY <= TOP_THRESHOLD) {
        shell.classList.remove('header-hidden');
      } else {
        shell.classList.add('header-hidden');
      }

      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });

    // Run once on load to set correct initial state (e.g. when page loads scrolled)
    onScroll();
  })();

  // Move the portal onto <body> so it escapes the nav's stacking context
  var portal = document.getElementById('search-portal');
  if (portal && portal.parentNode !== document.body) {
    document.body.appendChild(portal);
  }

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function scoreBook(book, query) {
    var q = query.toLowerCase().trim();
    if (!q) return 0;
    var title = book.title.toLowerCase();
    var subtitle = (book.subtitle || '').toLowerCase();
    var haystack = title + ' ' + subtitle + ' ' + book.lang.toLowerCase();

    if (title === q) return 100;
    if (title.startsWith(q)) return 85;
    if (title.includes(q)) return 70;
    if (subtitle.includes(q)) return 60;

    var words = q.split(/\s+/).filter(Boolean);
    if (words.length > 1 && words.every(function (w) { return haystack.includes(w); })) {
      return 45;
    }
    return 0;
  }

  function renderResult(r) {
    return (
      '<a class="search-result" href="/books/' + escapeHtml(r.slug) + '/">' +
        '<span class="search-result-title">' + escapeHtml(r.title) + '</span>' +
        '<span class="search-result-lang">' + escapeHtml(r.lang) + '</span>' +
      '</a>'
    );
  }

  var activeInput = null;

  function positionPortal() {
    if (!portal || !activeInput || portal.style.display === 'none') return;
    var rect = activeInput.getBoundingClientRect();
    portal.style.top = (rect.bottom + 8) + 'px';
    portal.style.left = rect.left + 'px';
    portal.style.width = rect.width + 'px';
  }

  function openPortal(input) {
    activeInput = input;
    portal.style.display = 'block';
    positionPortal();
  }

  function closePortal() {
    if (portal) portal.style.display = 'none';
    activeInput = null;
  }

  function runSearch(input) {
    var q = input.value;
    var qt = q ? q.trim() : '';
    if (!qt || qt.length < 1) {
      closePortal();
      return;
    }
    var matches = searchIndex
      .map(function (b) { return { b: b, s: scoreBook(b, qt) }; })
      .filter(function (r) { return r.s > 0; })
      .sort(function (a, b) { return b.s - a.s; })
      .map(function (r) { return r.b; });

    if (!matches.length) {
      portal.innerHTML = '<div class="search-empty">No books found</div>';
    } else {
      var html = matches.map(renderResult).join('');
      html +=
        '<a class="search-view-all" href="/search/?q=' +
        encodeURIComponent(qt) +
        '">View all ' + matches.length + ' ' +
        (matches.length === 1 ? 'result' : 'results') +
        ' <span aria-hidden="true">→</span></a>';
      portal.innerHTML = html;
    }
    openPortal(input);
    portal.scrollTop = 0;
  }

  function attachSearch(inputId) {
    var input = document.getElementById(inputId);
    if (!input) return;

    input.addEventListener('input', function () { runSearch(input); });
    input.addEventListener('focus', function () {
      if (input.value.trim().length >= 1) runSearch(input);
    });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closePortal();
        input.blur();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        var q = input.value.trim();
        if (!q) return;
        closePortal();
        window.location.href = '/search/?q=' + encodeURIComponent(q);
      }
    });
  }

  attachSearch('nav-search');
  attachSearch('nav-search-mobile');

  // Dismiss on outside click
  document.addEventListener('click', function (e) {
    if (!portal || portal.style.display === 'none') return;
    if (e.target === activeInput) return;
    if (portal.contains(e.target)) return;
    closePortal();
  });

  window.addEventListener('scroll', positionPortal, { passive: true });
  window.addEventListener('resize', positionPortal);

  // Hamburger menu toggle + outside click dismiss
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    function openMenu() {
      menu.classList.remove('menu-hidden');
      menu.classList.add('menu-visible');
    }
    function closeMenu() {
      menu.classList.remove('menu-visible');
      menu.classList.add('menu-hidden');
    }

    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      if (menu.classList.contains('menu-visible')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('click', function (e) {
      if (
        menu.classList.contains('menu-visible') &&
        !menu.contains(e.target) &&
        !toggle.contains(e.target)
      ) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeMenu();
    });
  })();
</script>
