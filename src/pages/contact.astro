---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';

const WHATSAPP_RAW = '917903291954';
const WHATSAPP_DISPLAY = '+91 79032 91954';
const EMAIL = 'info@jagannathpublications.com';
---

<Base
  title="Contact Us"
  description="Reach Jagannath Publications for book orders, bulk enquiries, or seva opportunities. WhatsApp and email support."
>
  <Header />

  <main class="pt-28 pb-20">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-5 sm:px-8 text-center mb-12">
      <p class="font-display text-xs tracking-[0.3em] uppercase text-brand-500 font-semibold mb-3">
        Get in Touch
      </p>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--text-primary)] leading-tight mb-5">
        We'd love to hear from you
      </h1>
      <p class="font-display text-lg text-[var(--text-muted)] leading-relaxed max-w-2xl mx-auto">
        Whether you're placing an order, arranging a bulk purchase for your temple, or
        simply want to know more — reach out through any of these channels.
      </p>
    </section>

    <!-- Ornament divider -->
    <div class="max-w-3xl mx-auto px-5 sm:px-8 mb-10">
      <div class="ornament">
        <svg width="42" height="22" viewBox="0 0 42 22" fill="none" class="text-[var(--accent)]" aria-hidden="true">
          <path d="M21 20 C21 20 8 20 4 14 C9 14 13 12 15 8 C16 11 18 13 21 14 C24 13 26 11 27 8 C29 12 33 14 38 14 C34 20 21 20 21 20 Z" fill="currentColor" opacity="0.45"/>
          <path d="M21 14 C21 14 17 11 18 5 C20 7 21 10 21 14 Z M21 14 C21 14 25 11 24 5 C22 7 21 10 21 14 Z" fill="currentColor" opacity="0.55"/>
        </svg>
      </div>
    </div>

    <!-- Contact cards -->
    <section class="max-w-4xl mx-auto px-5 sm:px-8">
      <div class="grid sm:grid-cols-2 gap-5 sm:gap-6 mb-10">
        <!-- WhatsApp -->
        <a
          href={`https://wa.me/${WHATSAPP_RAW}?text=${encodeURIComponent('Hare Krishna! I have a question.')}`}
          target="_blank"
          rel="noopener"
          class="contact-card whatsapp-card"
        >
          <div class="contact-icon" style="background: linear-gradient(135deg, #25d366, #1fb856);">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 22h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          </div>
          <h3>WhatsApp</h3>
          <p class="contact-value">{WHATSAPP_DISPLAY}</p>
          <p class="contact-hint">Fastest reply — usually within a few hours</p>
          <span class="contact-cta">Message us <span aria-hidden="true">→</span></span>
        </a>

        <!-- Email -->
        <a href={`mailto:${EMAIL}`} class="contact-card email-card">
          <div class="contact-icon" style="background: linear-gradient(135deg, #f97316, #ea580c);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
          </div>
          <h3>Email</h3>
          <p class="contact-value">{EMAIL}</p>
          <p class="contact-hint">For orders, bulk enquiries, and distribution partnerships</p>
          <span class="contact-cta">Write to us <span aria-hidden="true">→</span></span>
        </a>
      </div>

      <!-- Address / Hours card -->
      <div class="info-card">
        <div class="grid sm:grid-cols-2 gap-8">
          <div>
            <h4>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              Publishing Base
            </h4>
            <p>
              Bhubaneswar, Odisha<br />
              India — 751002
            </p>
          </div>

          <div>
            <h4>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Response Hours
            </h4>
            <p>
              Mon – Sat, 9:00 – 19:00 IST<br />
              Closed on Ekadasi & major festivals
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ hint -->
      <div class="text-center mt-10 text-sm text-[var(--text-muted)] font-display">
        <p>Looking for a specific title? <a href="/books/" class="text-brand-500 hover:text-brand-600 font-semibold">Browse the full catalog →</a></p>
      </div>
    </section>
  </main>

  <Footer />
  <Cart />
</Base>

<style>
  .contact-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }
  .contact-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.03), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .contact-card:hover {
    transform: translateY(-4px);
    border-color: var(--brand);
    box-shadow: 0 20px 40px rgba(74, 28, 21, 0.1);
  }
  .contact-card:hover::before {
    opacity: 1;
  }
  .whatsapp-card:hover {
    border-color: #25d366;
    box-shadow: 0 20px 40px rgba(37, 211, 102, 0.15);
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 1rem;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }
  .contact-card h3 {
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--text-primary);
    margin-bottom: 0.375rem;
    position: relative;
    z-index: 1;
  }
  .contact-value {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    z-index: 1;
  }
  .contact-hint {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .contact-cta {
    display: inline-block;
    margin-top: 1rem;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand);
    position: relative;
    z-index: 1;
  }

  .info-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.6), rgba(250, 246, 238, 0.4));
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 2rem;
    backdrop-filter: blur(8px);
  }
  .info-card h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 700;
    margin-bottom: 0.625rem;
  }
  .info-card p {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
</style>
