---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Cart from '../../components/Cart.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { title, subtitle, language, publisher, price, currency = 'INR', coverFront, coverBack, indexPages, available, dimensions } = book.data;
const { Content } = await book.render();

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';

const whatsappMsg = `Hare Krishna! I'd like to order:\n\n${title}${subtitle ? ' — ' + subtitle : ''} (${language})\n\nPlease let me know availability and pricing. Thank you!`;
const whatsappUrl = `https://wa.me/917903291954?text=${encodeURIComponent(whatsappMsg)}`;
---

<Base title={title} description={`${title} by Srila Gour Govinda Swami Maharaja. ${language} edition.`}>
  <Header />

  <main class="pt-24 pb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <!-- Back link -->
      <a href="/books/" class="inline-flex items-center gap-2 font-sans text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        Back to Library
      </a>

      <div class="grid md:grid-cols-[1fr_1.2fr] gap-10 lg:gap-16">
        <!-- Left: Cover images — horizontal swipe on mobile, stacked on desktop -->
        <div class="book-images">
          <div class="book-images-scroll">
            <!-- Front cover -->
            <div class="book-slide">
              <div class="rounded-2xl overflow-hidden shadow-2xl bg-[var(--bg-secondary)]">
                <img src={coverFront} alt={`${title} — Front Cover`} class="w-full" />
              </div>
              <p class="slide-label">Front Cover</p>
            </div>

            <!-- Back cover -->
            {coverBack && (
              <div class="book-slide">
                <div class="rounded-2xl overflow-hidden shadow-lg bg-[var(--bg-secondary)]">
                  <img src={coverBack} alt={`${title} — Back Cover`} class="w-full" loading="lazy" />
                </div>
                <p class="slide-label">Back Cover</p>
              </div>
            )}

            <!-- Index / Table of Contents pages -->
            {indexPages && indexPages.length > 0 && (
              indexPages.map((page, i) => (
                <div class="book-slide">
                  <div class="rounded-xl overflow-hidden shadow-md bg-[var(--bg-secondary)]">
                    <img src={page} alt={`${title} — Contents page ${i + 1}`} class="w-full" loading="lazy" />
                  </div>
                  <p class="slide-label">Contents {i + 1}</p>
                </div>
              ))
            )}
          </div>
          <div class="slide-dots" id="slide-dots"></div>
        </div>

        <!-- Right: Book info -->
        <div class="md:sticky md:top-24 md:self-start">
          <div class="space-y-6">
            <!-- Language badge -->
            <div class="flex items-center gap-2">
              <span class="px-3 py-1 rounded-full font-sans text-xs font-medium bg-[var(--bg-secondary)] text-[var(--text-muted)] border border-[var(--border)]">
                {language}
              </span>
              {publisher && (
                <span class="font-sans text-xs text-[var(--text-subtle)]">{publisher}</span>
              )}
            </div>

            <!-- Title -->
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-[var(--text-primary)] leading-tight">
              {title}
            </h1>
            {subtitle && (
              <p class="font-body text-lg text-[var(--text-muted)] italic -mt-2">{subtitle}</p>
            )}

            <p class="font-sans text-sm text-[var(--text-muted)]">
              By <span class="text-[var(--text-secondary)]">Sri Srimad Gour Govinda Swami Maharaja</span>
            </p>

            <!-- Price -->
            {priceDisplay && (
              <p class="font-display text-2xl font-bold text-[var(--accent)]">{priceDisplay}</p>
            )}

            <!-- Description -->
            <div class="prose prose-sm max-w-none text-[var(--text-muted)] font-body leading-relaxed">
              <Content />
            </div>

            <!-- Dimensions -->
            {dimensions && (
              <div class="flex flex-wrap gap-x-6 gap-y-2 py-3 border-y border-[var(--border)] font-sans text-sm text-[var(--text-muted)]">
                {dimensions.length && dimensions.breadth && (
                  <div><span class="text-[var(--text-subtle)]">Size</span> <span class="text-[var(--text-secondary)] font-medium">{dimensions.length} × {dimensions.breadth} cm</span></div>
                )}
                {dimensions.pages && (
                  <div><span class="text-[var(--text-subtle)]">Pages</span> <span class="text-[var(--text-secondary)] font-medium">{dimensions.pages}</span></div>
                )}
                {dimensions.weight && (
                  <div><span class="text-[var(--text-subtle)]">Weight</span> <span class="text-[var(--text-secondary)] font-medium">{dimensions.weight}g</span></div>
                )}
              </div>
            )}

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 pt-4">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener"
                class="flex-1 flex items-center justify-center gap-2.5 py-3.5 bg-maroon-500 dark:bg-saffron-400 text-parchment-100 dark:text-maroon-800 rounded-xl font-sans font-semibold text-sm hover:opacity-90 transition shadow-lg"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Order via WhatsApp
              </a>
              <button
                onclick={`cartAdd('${book.slug}', '${title.replace(/'/g, "\\'")}', '${language}'); toggleCart();`}
                class="flex-1 flex items-center justify-center gap-2 py-3.5 border-2 border-[var(--border-strong)] text-[var(--text-secondary)] rounded-xl font-sans font-semibold text-sm hover:bg-[var(--bg-secondary)] transition"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
                Add to Selection
              </button>
            </div>

            <!-- Availability -->
            <p class="font-sans text-xs text-[var(--text-subtle)]">
              {available !== false ? 'In stock — contact us to order' : 'Currently out of stock'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <Cart />

  <style>
    /* Desktop: stacked vertically */
    .book-images-scroll {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .slide-label {
      font-size: 0.7rem;
      color: var(--text-subtle);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-align: center;
      margin-top: 0.5rem;
      font-family: var(--font-sans, system-ui);
    }
    .slide-dots { display: none; }

    /* Mobile: horizontal swipe */
    @media (max-width: 768px) {
      .book-images { position: relative; }
      .book-images-scroll {
        flex-direction: row;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        gap: 12px;
        padding-bottom: 8px;
      }
      .book-images-scroll::-webkit-scrollbar { display: none; }
      .book-slide {
        flex: 0 0 85%;
        scroll-snap-align: center;
      }
      .slide-dots {
        display: flex;
        justify-content: center;
        gap: 6px;
        padding: 10px 0;
      }
      .slide-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--border);
        transition: all 0.2s;
      }
      .slide-dot.active {
        background: var(--accent);
        transform: scale(1.3);
      }
    }
  </style>

  <script is:inline>
    // Dot indicators for mobile image slider
    (function() {
      var scroll = document.querySelector('.book-images-scroll');
      var dotsEl = document.getElementById('slide-dots');
      if (!scroll || !dotsEl) return;
      var slides = scroll.querySelectorAll('.book-slide');
      if (slides.length < 2) return;

      // Create dots
      slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.className = 'slide-dot' + (i === 0 ? ' active' : '');
        dotsEl.appendChild(dot);
      });
      var dots = dotsEl.querySelectorAll('.slide-dot');

      // Update active dot on scroll
      scroll.addEventListener('scroll', function() {
        var scrollLeft = scroll.scrollLeft;
        var slideWidth = slides[0].offsetWidth + 12; // gap
        var idx = Math.round(scrollLeft / slideWidth);
        dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
      });
    })();
  </script>
</Base>
