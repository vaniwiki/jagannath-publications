---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Cart from '../../components/Cart.astro';
import SmartImage from '../../components/SmartImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { title, subtitle, language, price, currency = 'INR', coverFront, coverBack, indexPages, available, dimensions } = book.data;
const { Content } = await book.render();

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';

const whatsappMsg = `Hare Krishna! I'd like to order:\n\n${title}${subtitle ? ' — ' + subtitle : ''} (${language})\n\nPlease let me know availability and pricing. Thank you!`;
const whatsappUrl = `https://wa.me/917903291954?text=${encodeURIComponent(whatsappMsg)}`;

// Build the list of images for this book, in order.
const images: { src: string; alt: string; kind: string }[] = [
  { src: coverFront, alt: `${title} — Front Cover`, kind: 'front' },
];
if (coverBack)  images.push({ src: coverBack, alt: `${title} — Back Cover`, kind: 'back' });
if (indexPages) indexPages.forEach((p, i) => images.push({ src: p, alt: `${title} — Contents ${i + 1}`, kind: 'index' }));

const showControls = images.length > 1;
---

<Base title={title} description={`${title} by Srila Gour Govinda Swami Maharaja. ${language} edition.`}>
  <Header />

  <main class="pt-28 pb-20">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <!-- Back link -->
      <a href="/books/" class="inline-flex items-center gap-2 font-display text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition mb-8">
        <span>←</span> Back to Library
      </a>

      <div class="grid md:grid-cols-[1fr_1.2fr] gap-10 lg:gap-16">
        <!-- Left: Cover images carousel -->
        <div class="jp-slider" data-jp-slider>
          <div class="jp-slider__viewport">
            <div class="jp-slider__track" data-jp-slider-track tabindex="0">
              {images.map((img, i) => (
                <div class="jp-slider__slide">
                  <div class="book-frame">
                    <SmartImage
                      src={img.src}
                      alt={img.alt}
                      class="book-frame__img"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      {...(i === 0 ? { fetchpriority: 'high' } : {})}
                    />
                  </div>
                </div>
              ))}
            </div>

            {showControls && (
              <>
                <button
                  class="jp-slider__arrow jp-slider__arrow--prev"
                  data-jp-slider-prev
                  aria-label="Previous image"
                  type="button"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                </button>
                <button
                  class="jp-slider__arrow jp-slider__arrow--next"
                  data-jp-slider-next
                  aria-label="Next image"
                  type="button"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </button>
              </>
            )}
          </div>

          {showControls && (
            <div class="jp-slider__pills" data-jp-slider-pills role="tablist" aria-label="Book image navigation">
              {images.map((_, i) => (
                <button
                  type="button"
                  class={`jp-slider__pill${i === 0 ? ' is-active' : ''}`}
                  data-jp-slider-pill={i}
                  role="tab"
                  aria-label={`Go to image ${i + 1}`}
                ></button>
              ))}
            </div>
          )}
        </div>

        <!-- Right: Book info -->
        <div class="md:sticky md:top-28 md:self-start">
          <div class="space-y-5">
            <!-- Title -->
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-[var(--text-primary)] leading-tight">
              {title}
              {subtitle && <span class="block text-xl sm:text-2xl text-[var(--text-secondary)] mt-1">{subtitle}</span>}
            </h1>

            <!-- Language label -->
            <p class="font-display text-xs tracking-[0.25em] uppercase text-[var(--text-muted)]">
              Language: <span class="text-[var(--text-primary)] font-semibold">{language}</span>
            </p>

            <!-- Price -->
            {priceDisplay && (
              <p class="font-display text-2xl font-bold text-brand-500">{priceDisplay}</p>
            )}

            <!-- Description -->
            <div class="prose prose-sm max-w-none text-[var(--text-muted)] font-display leading-relaxed">
              <p class="text-[var(--text-primary)] font-semibold inline">Description: </p>
              <Content />
            </div>

            <!-- Dimensions table -->
            {dimensions && (
              <div class="specs-box rounded-xl border border-[var(--border-strong)] overflow-hidden">
                {dimensions.length && dimensions.breadth && (
                  <div class="spec-row flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
                    <span class="font-display text-sm text-[var(--text-muted)]">Size</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.length} × {dimensions.breadth} cm</span>
                  </div>
                )}
                {dimensions.pages && (
                  <div class="spec-row flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
                    <span class="font-display text-sm text-[var(--text-muted)]">Pages</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.pages}</span>
                  </div>
                )}
                {dimensions.weight && (
                  <div class="spec-row flex items-center justify-between px-5 py-3">
                    <span class="font-display text-sm text-[var(--text-muted)]">Weight</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.weight}g</span>
                  </div>
                )}
              </div>
            )}

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <button
                data-cart-btn={book.slug}
                data-title={title}
                data-language={language}
                class="add-to-bag-btn add-to-bag-btn--primary flex-1"
              >
                <img src="/images/bag.png" alt="" class="add-to-bag-btn__icon" />
                <span class="add-to-bag-btn__label">Add to Bag</span>
              </button>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener"
                class="flex-1 flex items-center justify-center gap-2 py-3 border-2 border-[var(--border-strong)] text-[var(--text-primary)] rounded-full font-display font-semibold text-sm tracking-wide hover:border-brand-500 hover:text-brand-500 transition"
              >
                Buy Now ↗
              </a>
            </div>

            <!-- Availability -->
            <p class="font-display text-xs text-[var(--text-subtle)]">
              {available !== false ? 'In stock — contact us to order' : 'Currently out of stock'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <Cart />

  <script is:inline>
    (function () {
      function init() {
        document.querySelectorAll('[data-jp-slider]').forEach(function (root) {
          var track = root.querySelector('[data-jp-slider-track]');
          var prev  = root.querySelector('[data-jp-slider-prev]');
          var next  = root.querySelector('[data-jp-slider-next]');
          var pills = root.querySelectorAll('[data-jp-slider-pill]');
          if (!track) return;

          var slides = track.querySelectorAll('.jp-slider__slide');
          if (slides.length < 2) return;

          function gap() { return 16; }
          function currentIndex() {
            var w = slides[0].offsetWidth + gap();
            if (w <= 0) return 0;
            return Math.max(0, Math.min(slides.length - 1, Math.round(track.scrollLeft / w)));
          }

          function goTo(i) {
            if (i < 0) i = 0;
            if (i > slides.length - 1) i = slides.length - 1;
            var w = slides[0].offsetWidth + gap();
            track.scrollTo({ left: w * i, behavior: 'smooth' });
          }

          function updateUI() {
            var idx = currentIndex();
            pills.forEach(function (p, i) { p.classList.toggle('is-active', i === idx); });
            if (prev) prev.disabled = idx <= 0;
            if (next) next.disabled = idx >= slides.length - 1;
          }

          track.addEventListener('scroll', function () {
            window.requestAnimationFrame(updateUI);
          }, { passive: true });

          if (prev) prev.addEventListener('click', function () { goTo(currentIndex() - 1); });
          if (next) next.addEventListener('click', function () { goTo(currentIndex() + 1); });

          pills.forEach(function (p, i) {
            p.addEventListener('click', function () { goTo(i); });
          });

          track.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(currentIndex() - 1); }
            if (e.key === 'ArrowRight') { e.preventDefault(); goTo(currentIndex() + 1); }
          });

          window.addEventListener('resize', function () {
            window.requestAnimationFrame(updateUI);
          });

          updateUI();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</Base>
