---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Cart from '../../components/Cart.astro';
import SmartImage from '../../components/SmartImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { title, subtitle, language, price, currency = 'INR', coverFront, coverBack, indexPages, available, dimensions } = book.data;
const { Content } = await book.render();

const priceDisplay = price
  ? currency === 'INR' ? `₹${price}` : `${price} ${currency}`
  : '';

const whatsappMsg = `Hare Krishna! I'd like to order:\n\n${title}${subtitle ? ' — ' + subtitle : ''} (${language})\n\nPlease let me know availability and pricing. Thank you!`;
const whatsappUrl = `https://wa.me/917903291954?text=${encodeURIComponent(whatsappMsg)}`;

const safeTitle = title.replace(/'/g, "\\'");
---

<Base title={title} description={`${title} by Srila Gour Govinda Swami Maharaja. ${language} edition.`}>
  <Header />

  <main class="pt-28 pb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <!-- Back link -->
      <a href="/books/" class="inline-flex items-center gap-2 font-display text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition mb-8">
        <span>←</span> Back to Library
      </a>

      <div class="grid md:grid-cols-[1fr_1.2fr] gap-10 lg:gap-16">
        <!-- Left: Cover images slider -->
        <div class="book-images">
          <div class="book-images-scroll">
            <div class="book-slide">
              <div class="rounded-2xl overflow-hidden shadow-xl bg-[var(--bg-secondary)]">
                <SmartImage src={coverFront} alt={`${title} — Front Cover`} class="w-full" loading="eager" fetchpriority="high" />
              </div>
            </div>

            {coverBack && (
              <div class="book-slide">
                <div class="rounded-2xl overflow-hidden shadow-lg bg-[var(--bg-secondary)]">
                  <SmartImage src={coverBack} alt={`${title} — Back Cover`} class="w-full" loading="lazy" />
                </div>
              </div>
            )}

            {indexPages && indexPages.length > 0 && indexPages.map((page, i) => (
              <div class="book-slide">
                <div class="rounded-xl overflow-hidden shadow-md bg-[var(--bg-secondary)]">
                  <SmartImage src={page} alt={`${title} — Contents ${i + 1}`} class="w-full" loading="lazy" />
                </div>
              </div>
            ))}
          </div>

          <!-- Slide dots -->
          <div class="slide-dots mt-4" id="slide-dots"></div>
        </div>

        <!-- Right: Book info -->
        <div class="md:sticky md:top-28 md:self-start">
          <div class="space-y-5">
            <!-- Title -->
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-[var(--text-primary)] leading-tight">
              {title}
              {subtitle && <span class="block text-xl sm:text-2xl text-[var(--text-secondary)] mt-1">{subtitle}</span>}
            </h1>

            <!-- Language label -->
            <p class="font-display text-xs tracking-[0.25em] uppercase text-[var(--text-muted)]">
              Language: <span class="text-[var(--text-primary)] font-semibold">{language}</span>
            </p>

            <!-- Price -->
            {priceDisplay && (
              <p class="font-display text-2xl font-bold text-brand-500">{priceDisplay}</p>
            )}

            <!-- Description -->
            <div class="prose prose-sm max-w-none text-[var(--text-muted)] font-display leading-relaxed">
              <p class="text-[var(--text-primary)] font-semibold inline">Description: </p>
              <Content />
            </div>

            <!-- Dimensions table -->
            {dimensions && (
              <div class="specs-box rounded-xl border border-[var(--border-strong)] overflow-hidden">
                {dimensions.length && dimensions.breadth && (
                  <div class="spec-row flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
                    <span class="font-display text-sm text-[var(--text-muted)]">Size</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.length} × {dimensions.breadth} cm</span>
                  </div>
                )}
                {dimensions.pages && (
                  <div class="spec-row flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
                    <span class="font-display text-sm text-[var(--text-muted)]">Pages</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.pages}</span>
                  </div>
                )}
                {dimensions.weight && (
                  <div class="spec-row flex items-center justify-between px-5 py-3">
                    <span class="font-display text-sm text-[var(--text-muted)]">Weight</span>
                    <span class="font-display text-sm font-semibold text-[var(--text-primary)]">{dimensions.weight}g</span>
                  </div>
                )}
              </div>
            )}

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <button
                data-cart-btn={book.slug}
                data-title={title}
                data-language={language}
                class="add-to-bag-btn flex-1 flex items-center justify-center gap-2 py-3 bg-brand-500 hover:bg-brand-600 text-white rounded-full font-display font-semibold text-sm tracking-wide transition shadow-md"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7 18a2 2 0 100 4 2 2 0 000-4zM17 18a2 2 0 100 4 2 2 0 000-4zM4 3h2.5l2 10.5h10l2-7.5H8"/></svg>
                Add to Bag
              </button>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener"
                class="flex-1 flex items-center justify-center gap-2 py-3 border-2 border-[var(--border-strong)] text-[var(--text-primary)] rounded-full font-display font-semibold text-sm tracking-wide hover:border-brand-500 hover:text-brand-500 transition"
              >
                Buy Now ↗
              </a>
            </div>

            <!-- Availability -->
            <p class="font-display text-xs text-[var(--text-subtle)]">
              {available !== false ? 'In stock — contact us to order' : 'Currently out of stock'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <Cart />

  <style>
    .book-images-scroll {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .slide-dots { display: none; }

    @media (max-width: 768px) {
      .book-images { position: relative; }
      .book-images-scroll {
        flex-direction: row;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        gap: 12px;
        padding-bottom: 4px;
      }
      .book-images-scroll::-webkit-scrollbar { display: none; }
      .book-slide {
        flex: 0 0 85%;
        scroll-snap-align: center;
      }
      .slide-dots {
        display: flex;
        justify-content: center;
        gap: 6px;
      }
      .slide-dot {
        width: 24px;
        height: 4px;
        border-radius: 2px;
        background: var(--border-strong);
        transition: all 0.2s;
      }
      .slide-dot.active {
        background: var(--text-primary);
        width: 32px;
      }
    }
  </style>

  <script is:inline>
    (function() {
      var scroll = document.querySelector('.book-images-scroll');
      var dotsEl = document.getElementById('slide-dots');
      if (!scroll || !dotsEl) return;
      var slides = scroll.querySelectorAll('.book-slide');
      if (slides.length < 2) return;

      slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.className = 'slide-dot' + (i === 0 ? ' active' : '');
        dotsEl.appendChild(dot);
      });
      var dots = dotsEl.querySelectorAll('.slide-dot');

      scroll.addEventListener('scroll', function() {
        var slideWidth = slides[0].offsetWidth + 12;
        var idx = Math.round(scroll.scrollLeft / slideWidth);
        dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
      });
    })();
  </script>
</Base>
