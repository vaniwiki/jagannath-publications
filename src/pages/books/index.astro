---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookCard from '../../components/BookCard.astro';
import Cart from '../../components/Cart.astro';
import LanguagePills from '../../components/LanguagePills.astro';
import { getCollection } from 'astro:content';
import { excludeFeatured } from '../../lib/books';

const allBooks = await getCollection('books');
const books = excludeFeatured(allBooks).sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
---

<Base title="All Books">
  <Header />

  <main class="pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="font-display text-3xl sm:text-4xl font-bold text-[var(--text-primary)] mb-2">
          All {books.length} Titles
        </h1>
        <p class="font-display text-sm text-[var(--text-muted)]">
          The complete catalog of sacred literature.
        </p>
      </div>

      <!-- Language pills -->
      <div class="flex justify-center mb-10">
        <LanguagePills />
      </div>

      <!-- Book grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5 sm:gap-7">
        {books.map(book => (
          <BookCard
            slug={book.slug}
            title={book.data.title}
            language={book.data.language}
            coverFront={book.data.coverFront}
            price={book.data.price}
            currency={book.data.currency}
          />
        ))}
      </div>
    </div>
  </main>

  <Footer />
  <Cart />
</Base>
