---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';

const updated = 'April 2026';
---

<Base
  title="Privacy Policy"
  description="How Jagannath Publications handles the limited information you share while browsing or placing orders."
>
  <Header />

  <main class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-5 sm:px-8">
      <!-- Hero -->
      <div class="text-center mb-10">
        <p class="font-display text-xs tracking-[0.3em] uppercase text-brand-500 font-semibold mb-3">
          Privacy Policy
        </p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-[var(--text-primary)] mb-4">
          Your Trust, Our Dharma
        </h1>
        <p class="font-display text-sm text-[var(--text-muted)]">Last updated: {updated}</p>
      </div>

      <!-- Ornament -->
      <div class="ornament mb-10">
        <svg width="36" height="10" viewBox="0 0 36 10" fill="none" class="text-[var(--accent)]" aria-hidden="true">
          <path d="M8 5 L12 2 L16 5 L12 8 Z M18 5 L22 1 L26 5 L22 9 Z M27 5 L30 3 L33 5 L30 7 Z" fill="currentColor" opacity="0.5"/>
        </svg>
      </div>

      <!-- Summary callout -->
      <div class="summary-card mb-10">
        <div class="summary-icon">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
          </svg>
        </div>
        <div>
          <h4>The short version</h4>
          <p>
            We don't run a payment gateway. We don't track you. Orders happen over WhatsApp
            or email, and only the information <em>you</em> choose to share reaches us.
          </p>
        </div>
      </div>

      <article class="legal-content space-y-7">
        <section>
          <h2>Information We Collect</h2>
          <p>
            Because all orders are placed through WhatsApp or email, the only information
            we ever receive is what you directly send to us — typically your name, shipping
            address, the titles you would like, and your contact number or email. We do not
            run any sign-up forms, account system, or payment form on this website.
          </p>
        </section>

        <section>
          <h2>Your Cart</h2>
          <p>
            The "bag" you build while browsing is stored entirely in your own browser's
            local storage. It never reaches our servers. Clearing your browser data will
            remove it.
          </p>
        </section>

        <section>
          <h2>Cookies & Analytics</h2>
          <p>
            This site does not set tracking cookies and does not use third-party analytics
            services such as Google Analytics, Meta Pixel, or advertising SDKs. Standard
            server logs (IP address, user agent, timestamp) may be retained briefly by our
            hosting provider for security and debugging purposes.
          </p>
        </section>

        <section>
          <h2>How We Use the Information You Share</h2>
          <p>Your shared details are used only to:</p>
          <ul>
            <li>Confirm your order and answer any questions</li>
            <li>Prepare and dispatch your package</li>
            <li>Inform you of shipment updates or stock availability</li>
          </ul>
        </section>

        <section>
          <h2>Third Parties</h2>
          <p>
            We share only what is necessary with the courier for shipping. We do not sell,
            rent, or exchange your information with any other party — ever.
          </p>
        </section>

        <section>
          <h2>Retention & Removal</h2>
          <p>
            We keep order correspondence long enough to resolve any delivery issues. If you
            would like your records removed, write to us and we will delete them promptly.
          </p>
        </section>

        <section>
          <h2>Questions</h2>
          <p>
            For any privacy-related query, reach us at
            <a href="mailto:info@jagannathpublications.com" class="text-brand-500 hover:text-brand-600 font-semibold">info@jagannathpublications.com</a>
            or via <a href="/contact/" class="text-brand-500 hover:text-brand-600 font-semibold">WhatsApp</a>.
          </p>
        </section>
      </article>
    </div>
  </main>

  <Footer />
  <Cart />
</Base>

<style>
  .summary-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.06), rgba(201, 169, 110, 0.06));
    border: 1px solid rgba(249, 115, 22, 0.2);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
  }
  .summary-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--brand);
    color: white;
    flex-shrink: 0;
  }
  .summary-card h4 {
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 0.375rem;
  }
  .summary-card p {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .summary-card em {
    font-style: italic;
    color: var(--text-primary);
  }

  .legal-content section h2 {
    font-family: 'Gatwick', Georgia, serif;
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--text-primary);
    margin-bottom: 0.625rem;
    position: relative;
    padding-left: 1rem;
  }
  .legal-content section h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.375rem;
    bottom: 0.375rem;
    width: 3px;
    background: linear-gradient(180deg, var(--brand), var(--accent));
    border-radius: 2px;
  }
  .legal-content section p,
  .legal-content section ul {
    font-family: 'Gatwick', Georgia, serif;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }
  .legal-content section ul {
    list-style: none;
    padding-left: 0;
    margin-top: 0.75rem;
  }
  .legal-content section ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .legal-content section ul li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--brand);
    opacity: 0.55;
    font-size: 0.75em;
    top: 0.25em;
  }
</style>
