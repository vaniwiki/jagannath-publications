{
  "name": "jagannath-publications",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev --port 8096",
    "build": "npm run optimize-images && astro build",
    "preview": "astro preview --port 8096",
    "optimize-images": "node scripts/optimize_images.mjs",
    "format": "prettier --write \"**/*.{astro,js,mjs,ts,md,json,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{astro,js,mjs,ts,md,json,css,yml,yaml}\"",
    "lint": "eslint . --ext .js,.mjs,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.mjs,.ts,.astro --fix"
  },
  "dependencies": {
    "astro": "^5.7.10",
    "@astrojs/tailwind": "^6.0.2",
    "tailwindcss": "^3.4.17",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "eslint": "^9.13.0",
    "eslint-plugin-astro": "^1.3.0",
    "@typescript-eslint/parser": "^8.12.2",
    "globals": "^15.11.0"
  }
}
